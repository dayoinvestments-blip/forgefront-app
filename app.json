{
  "expo": {
    "name": "ForgeFront",
    "slug": "forgefront",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0C0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.forgefront.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan documents for job tracking",
        "NSPhotoLibraryUsageDescription": "Used to attach photos to job records"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0C0F"
      },
      "package": "app.forgefront.android",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "ForgeFront",
      "shortName": "ForgeFront",
      "description": "SDVOSB contract intelligence, AI bid writing, and job management for veteran-owned contractors.",
      "themeColor": "#00E5A0",
      "backgroundColor": "#0A0C0F",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}